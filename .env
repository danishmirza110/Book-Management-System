# ─────────────────────────────────────────────────────────────────
# BookShelf – Environment Configuration
# ─────────────────────────────────────────────────────────────────
#
# Copy this file to `.env` and fill in your MockAPI URL.
# Leave blank to run in Demo Mode (in-memory data).
#
# HOW TO GET A FREE MOCKAPI ENDPOINT:
#  1. Go to https://mockapi.io and create a free account.
#  2. Create a new project (e.g. "bookshelf").
#  3. Add a resource called "books" with these fields:
#       title   (String)
#       author  (String)
#       genre   (String)
#       year    (Number)
#  4. MockAPI will give you a URL like:
#       https://XXXXXXXX.mockapi.io/api/v1/books
#  5. Paste just the base (without /books) below.
#
# ─────────────────────────────────────────────────────────────────

VITE_API_URL=https://6a15455d91ff9a63de07c62c.mockapi.io/books
